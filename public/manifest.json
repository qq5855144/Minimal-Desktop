{
  "manifest_version": 3,
  "name": "Minimal Desktop",
  "short_name": "Minimal Desktop",
  "version": "1.0.0",
  "description": "An iOS-style new tab desktop with widgets, wallpapers, search, and folders.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*", "images/*", "favicon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
